      showToast(p==='granted'?'알림이 허용되었습니다 🔔':'알림 권한이 ' +(p==='denied'?'차단되었습니다':'설정되지 않았습니다'), p==='granted'?'success':'error');
      if(state.currentView==='settings') renderSettings();
