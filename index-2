function createTone(freq = 880, duration = 0.12, volume = 0.5) {
  try {
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();

    osc.type = 'sine';
    osc.frequency.value = freq;

    gain.gain.value = volume;

    osc.connect(gain);
    gain.connect(audioCtx.destination);

    osc.start();

    gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
    osc.stop(audioCtx.currentTime + duration);
  } catch(e) {}
}

function playCompleteSound() {
  if(state.customSfx) {
    playCustomAudio(state.customSfx, state.sfxVolume);
    return;
  }

  createTone(1046, 0.10, state.sfxVolume);
  setTimeout(() => createTone(1318, 0.12, state.sfxVolume), 90);
}

function playAlarmSound() {
  if(state.customAlarm) {
    playCustomAudio(state.customAlarm, state.alarmVolume);
    return;
  }

  let delay = 0;

  [880, 1174, 1567, 1174, 880].forEach(freq => {
    setTimeout(() => {
      createTone(freq, 0.35, Math.max(state.alarmVolume, 0.2));
    }, delay);

    delay += 350;
  });

  try {
    navigator.vibrate?.([300,120,300]);
  } catch(e) {}
}

