function linkify(text) {
  if(!text) return '';
  return text.replace(/(https?:\/\/[^\s<>"']+)/g, url =>
    `<a href="${url}" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" style="color:var(--accent-light);text-decoration:underline">${url}</a>`
  );
}
function renderList(container, todos, emptyMsg) {
  const el = document.getElementById(container);
