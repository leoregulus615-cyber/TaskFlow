async function finishGcalConnect(accessToken) {
  if(!accessToken) {
    setGcalConnectLoading(false);
    showToast('인증이 취소되었습니다', 'info');
    return;
  }
  state.gcal = { connected: true, account: '', token: accessToken, events: [], calendars: [] };
  try {
    const profileRes = await fetch('https://www.googleapis.com/oauth2/v2/userinfo', {
      headers: { Authorization: 'Bearer ' + accessToken }
    });
    if(profileRes.ok) {
      const profile = await profileRes.json();
      state.gcal.account = profile.email || profile.name || 'Google 계정';
      if(profile.picture) state.gcal.picture = profile.picture;
    }
  } catch(e) {}
  save();
  renderGcal();
  await fetchGcalData();
  setGcalConnectLoading(false);
  showToast((state.gcal.account ? state.gcal.account + ' ' : '') + '연동 완료 🎉', 'success');
}

function handleGcalOAuthReturn() {
  const hash = window.location.hash;
  if(!hash || hash.length < 2) return false;
  const params = new URLSearchParams(hash.slice(1));
  const clean = window.location.href.split('#')[0];
  history.replaceState(null, '', clean);
  if(params.get('error')) {
    setGcalConnectLoading(false);
    showToast('연동이 취소되었습니다', 'info');
    return true;
  }
  const token = params.get('access_token');
  if(token) finishGcalConnect(token);
  return !!token;
}

function getOAuthRedirectUri() {
  if(window.location.protocol === 'file:') return null;
  return window.location.origin + window.location.pathname;
}

function connectGoogleCalendarRedirect(clientId) {
  const redirectUri = getOAuthRedirectUri();
  if(!redirectUri) {
    setGcalConnectLoading(false);
    showToast('HTML 파일로 직접 열면 구글 연동이 안 됩니다. Live Server 등으로 localhost에서 열어주세요.', 'error');
    return;
  }
  sessionStorage.setItem('gcal_oauth_pending', '1');
  const scope = encodeURIComponent(GOOGLE_CALENDAR_SCOPES);
  const authUrl = `https://accounts.google.com/o/oauth2/v2/auth?client_id=${encodeURIComponent(clientId)}&redirect_uri=${encodeURIComponent(redirectUri)}&response_type=token&scope=${scope}&include_granted_scopes=true&prompt=consent`;
  window.location.href = authUrl;
}

function waitForGoogleGIS(maxMs) {
  return new Promise(resolve => {
    if(window.google?.accounts?.oauth2) return resolve(true);
    const start = Date.now();
    const t = setInterval(() => {
      if(window.google?.accounts?.oauth2) { clearInterval(t); resolve(true); }
      else if(Date.now() - start > maxMs) { clearInterval(t); resolve(false); }
    }, 80);
  });
}

async function connectGoogleCalendar() {
  const clientId = getGoogleClientId();
  if(!clientId) {
    showGcalSetupInline();
    return;
  }
  setGcalConnectLoading(true);
  showToast('구글 계정을 선택해주세요...', 'info');

  const gisReady = await waitForGoogleGIS(4000);
  if(gisReady) {
    try {
      if(!gcalTokenClient || gcalTokenClient._clientId !== clientId) {
        gcalTokenClient = google.accounts.oauth2.initTokenClient({
          client_id: clientId,
          scope: GOOGLE_CALENDAR_SCOPES,
          callback: (resp) => {
            if(resp.error) {
              setGcalConnectLoading(false);
              if(resp.error !== 'popup_closed') showToast('연동 실패: ' + resp.error, 'error');
              return;
            }
            finishGcalConnect(resp.access_token);
          }
        });
        gcalTokenClient._clientId = clientId;
      }
      gcalTokenClient.requestAccessToken({ prompt: state.gcal.connected ? '' : 'consent' });
      return;
    } catch(e) {
      console.warn('GIS token client failed', e);
    }
  }
  connectGoogleCalendarRedirect(clientId);
}

function disconnectGcal() {
  const token = state.gcal?.token;
  state.gcal = { connected: false, account: '', token: '', events: [], calendars: [] };
  gcalTokenClient = null;
  if(token && window.google?.accounts?.oauth2) {
    try { google.accounts.oauth2.revoke(token, () => {}); } catch(e) {}
  }
  save();
  renderGcal();
  showToast('연동이 해제되었습니다', 'info');
}

async function fetchGcalData() {
  const token = state.gcal?.token;
  if(!token) return;
  try {
    const calRes = await fetch('https://www.googleapis.com/calendar/v3/users/me/calendarList?maxResults=10', {
      headers: { Authorization: 'Bearer ' + token }
    });
    if(calRes.ok) {
      const calData = await calRes.json();
      state.gcal.calendars = (calData.items || []).map(c => ({
        id: c.id, summary: c.summary, backgroundColor: c.backgroundColor
      }));
    }
    const now = new Date();
    const start = new Date(now.getFullYear(), now.getMonth(), now.getDate()).toISOString();
    const end = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59).toISOString();
    const evRes = await fetch(
      'https://www.googleapis.com/calendar/v3/calendars/primary/events?timeMin=' + encodeURIComponent(start) +
      '&timeMax=' + encodeURIComponent(end) + '&singleEvents=true&orderBy=startTime&maxResults=20',
      { headers: { Authorization: 'Bearer ' + token } }
    );
    if(evRes.ok) {
      const evData = await evRes.json();
      state.gcal.events = (evData.items || []).map(ev => {
        const startDt = ev.start?.dateTime || ev.start?.date || '';
        const time = startDt.includes('T') ? startDt.slice(11, 16) : '';
        const date = startDt.slice(0, 10) || todayStr();
        return { title: ev.summary || '(제목 없음)', date, time };
      });
    }
    save();
    renderGcal();
  } catch(e) {
    showToast('일정을 가져오지 못했습니다. 동기화를 다시 시도해주세요.', 'error');
  }
}

