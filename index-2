  const subs = { urgent:'지금 바로 실행', high:'일정 계획', medium:'', low:'제거 검토' };
  const icons = { urgent:'🔴', high:'🟠', medium:'🔵', low:'⚪' };
  sel.innerHTML = ['urgent','high','medium','low'].map(p => {
    const sub = subs[p] ? ` — ${subs[p]}` : '';
    return `<option value="${p}">${icons[p]} ${getPriorityLabel(p)}${sub}</option>`;
  }).join('');
  if(selected) sel.value = selected;
}

