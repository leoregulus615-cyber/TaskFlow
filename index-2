function sendNotification(title, body) {
  if(Notification.permission==='granted') { new Notification(title,{body,icon:'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚡</text></svg>'}); }
}
function checkDueNotifications() {
  if(Notification.permission!=='granted') return;
  const now = new Date(); const before = (state.notifBefore||30)*60*1000;
  state.todos.filter(t=>!t.done&&t.due).forEach(t=>{
    const dueDate = new Date(t.due+'T23:59:59');
    const diff = dueDate - now;
    if(diff>0&&diff<=before) {
      const key = 'notif_'+t.id+'_'+t.due;
      if(!sessionStorage.getItem(key)) { sendNotification('마감 임박: '+t.title, `${fmt(t.due)} 마감입니다`); sessionStorage.setItem(key,'1'); }
    }
  });
}

