      t.doneAt = new Date().toISOString();
      if(!wasDone) {
        playCompleteSound();
        if(t.repeat && t.repeat !== 'none') {
          const nextDate = calcNextRepeatDate(t);
          if(nextDate) {
            const next = Object.assign({}, t, { id: genId(), done: false, doneAt: undefined, due: nextDate, created: new Date().toISOString() });
            delete next.doneAt;
            state.todos.push(next);
            showToast(`🔁 다음 반복 투두 생성됨 (${fmt(nextDate)})`, 'info');
          }
        }
      }
    }
    save();
    updateBadges();
    renderView(state.currentView);
updateFabVisibility();
renderStopwatch();
initSidebarSort();
applySidebarModes();
  }
}
