function calcNextRepeatDate(t) {
  const base = t.due ? new Date(t.due) : new Date();
  const r = t.repeat;
  if(!r || r==='none') return null;
  const next = new Date(base);
  if(r==='daily') next.setDate(next.getDate()+1);
  else if(r==='weekly') next.setDate(next.getDate()+7);
  else if(r==='monthly') next.setMonth(next.getMonth()+1);
  else if(r==='yearly') next.setFullYear(next.getFullYear()+1);
  else if(r==='weekdays') {
    next.setDate(next.getDate()+1);
    while(next.getDay()===0||next.getDay()===6) next.setDate(next.getDate()+1);
  } else if(r==='weekends') {
    next.setDate(next.getDate()+1);
    while(next.getDay()!==0&&next.getDay()!==6) next.setDate(next.getDate()+1);
  } else if(r.startsWith('custom:')) {
    const parts=r.split(':'); const n=parseInt(parts[1])||1; const unit=parts[2]||'day';
    if(unit==='day') next.setDate(next.getDate()+n);
    else if(unit==='week') next.setDate(next.getDate()+n*7);
    else if(unit==='month') next.setMonth(next.getMonth()+n);
    else if(unit==='year') next.setFullYear(next.getFullYear()+n);
  }
  return next.toISOString().split('T')[0];
}
function toggleDone(id) {
  const t = state.todos.find(x=>x.id===id);
  if(t) {
    const wasDone = t.done;
    t.done = !t.done;
