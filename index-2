  applyToastPosition();
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  const icons = { success:'fa-circle-check', error:'fa-circle-xmark', info:'fa-circle-info' };
  toast.innerHTML = `<i class="fa-solid ${icons[type]||'fa-circle-info'}" style="color:var(--${type==='success'?'success':type==='error'?'danger':'info'})"></i> ${msg}`;
  const dismiss = () => {
    if(!toast.parentNode) return;
    toast.style.animation = 'slideOut 0.3s ease forwards';
    setTimeout(() => toast.remove(), 280);
  };
  container.appendChild(toast);
  let timer = setTimeout(dismiss, 3000);
  toast.addEventListener('click', () => { clearTimeout(timer); dismiss(); });
}
function refreshPrioritySelectOptions(selected) {
