  if(state.upcomingFilter==='tomorrow') todos = state.todos.filter(x=>!x.done && ((x.due && new Date(x.due) <= tomorrow) || (!x.due && hasStarted(x))));
  else if(state.upcomingFilter==='week') todos = state.todos.filter(x=>!x.done && ((x.due && new Date(x.due) <= week) || (!x.due && hasStarted(x))));
  else if(state.upcomingFilter==='overdue') todos = state.todos.filter(x=>!x.done && ((x.due && isOverdue(x.due)) || (!x.due && hasStarted(x))));
  else todos = state.todos.filter(x=>!x.done && (x.due || hasStarted(x)));
