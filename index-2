function formatStopwatch(ms) {
  const totalSec = Math.floor(ms / 1000);
  const h = String(Math.floor(totalSec / 3600)).padStart(2,'0');
  const m = String(Math.floor((totalSec % 3600) / 60)).padStart(2,'0');
  const s = String(totalSec % 60).padStart(2,'0');
  return `${h}:${m}:${s}`;
}

function renderStopwatch() {
  const el = document.getElementById('stopwatch-display');
  if(el) el.textContent = formatStopwatch(state.stopwatch.elapsed);
}

function toggleStopwatch() {
  const btn = document.getElementById('stopwatch-toggle-btn');

  if(state.stopwatch.running) {
    clearInterval(state.stopwatch.interval);
    state.stopwatch.running = false;
    state.stopwatch.interval = null;

    if(btn) btn.innerHTML = '<i class="fa-solid fa-play"></i> 시작';
  } else {
    state.stopwatch.running = true;
    state.stopwatch.startedAt = Date.now() - state.stopwatch.elapsed;

    state.stopwatch.interval = setInterval(() => {
      state.stopwatch.elapsed = Date.now() - state.stopwatch.startedAt;
      renderStopwatch();
      save();
    }, 250);

    if(btn) btn.innerHTML = '<i class="fa-solid fa-pause"></i> 일시정지';
  }

  save();
}

function resetStopwatch() {
  clearInterval(state.stopwatch.interval);
  state.stopwatch.running = false;
  state.stopwatch.interval = null;
  state.stopwatch.elapsed = 0;
  renderStopwatch();

  const btn = document.getElementById('stopwatch-toggle-btn');
  if(btn) btn.innerHTML = '<i class="fa-solid fa-play"></i> 시작';

  save();
}

let draggingMenuBtn = null;
function initSidebarSort() {
  const list = document.getElementById('sidebar-menu-list');
  if(!list) return;
  clearSidebarDragState();
  applyMenuVisibility();
  list.classList.add('sidebar-sortable');
  list.querySelectorAll('.sidebar-btn[data-view]').forEach(btn => { btn.draggable = true; });
  if(list.dataset.sortInit === '1') return;
  list.dataset.sortInit = '1';
  list.addEventListener('dragstart', e => {
    const btn = e.target.closest('.sidebar-btn[data-view]');
    if(!btn) return;
    draggingMenuBtn = btn;
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/plain', btn.dataset.view);
    requestAnimationFrame(() => btn.classList.add('dragging-menu'));
  });
  list.addEventListener('dragend', () => {
    clearSidebarDragState();
    draggingMenuBtn = null;
    state.menuOrder = [...list.querySelectorAll('.sidebar-btn[data-view]')].map(b => b.dataset.view);
    save();
  });
  list.addEventListener('dragover', e => {
    e.preventDefault();
    const btn = e.target.closest('.sidebar-btn[data-view]');
    if(!btn || btn === draggingMenuBtn) return;
    list.querySelectorAll('.drag-over-menu').forEach(b => b.classList.remove('drag-over-menu'));
    btn.classList.add('drag-over-menu');
  });
  list.addEventListener('dragleave', e => {
    const btn = e.target.closest('.sidebar-btn[data-view]');
    if(btn) btn.classList.remove('drag-over-menu');
  });
  list.addEventListener('drop', e => {
    e.preventDefault();
    const btn = e.target.closest('.sidebar-btn[data-view]');
    if(!btn || !draggingMenuBtn || btn === draggingMenuBtn) return;
    btn.classList.remove('drag-over-menu');
    const rect = btn.getBoundingClientRect();
    const before = e.clientY < rect.top + rect.height / 2;
    if(before) list.insertBefore(draggingMenuBtn, btn);
    else list.insertBefore(draggingMenuBtn, btn.nextSibling);
    state.menuOrder = [...list.querySelectorAll('.sidebar-btn[data-view]')].map(b => b.dataset.view);
    save();
  });
  document.addEventListener('dragend', clearSidebarDragState);
}

