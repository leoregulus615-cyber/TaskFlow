function cancelListRename(idx, oldName) {
  document.getElementById(`list-label-${idx}`).style.display='';
  document.getElementById(`list-input-${idx}`).style.display='none';
}
function commitListRename(idx, oldName) {
  const inp = document.getElementById(`list-input-${idx}`);
  const newName = inp.value.trim();
  if(!newName) { cancelListRename(idx, oldName); return; }
  if(newName === oldName) { cancelListRename(idx, oldName); return; }
  if(state.lists.includes(newName)) { showToast('이미 존재하는 이름입니다','error'); return; }
  state.lists[state.lists.indexOf(oldName)] = newName;
  state.todos.forEach(t => { if(t.list===oldName) t.list=newName; });
  save(); renderSettings(); showToast(`'${oldName}' → '${newName}'으로 변경됨`,'success');
}
function initListSort() {
  const container = document.getElementById('lists-manager');
  if(!container) return;
  let draggingEl = null;
  container.querySelectorAll('.list-item-row').forEach(row => {
    row.addEventListener('dragstart', e => { draggingEl = row; row.style.opacity='0.4'; e.dataTransfer.effectAllowed='move'; e.dataTransfer.setData('text',''); });
    row.addEventListener('dragend', e => { draggingEl=null; row.style.opacity='1'; });
    row.addEventListener('dragover', e => { e.preventDefault(); if(draggingEl&&draggingEl!==row) { const rect=row.getBoundingClientRect(); const mid=rect.top+rect.height/2; if(e.clientY<mid) container.insertBefore(draggingEl,row); else container.insertBefore(draggingEl,row.nextSibling); } });
    row.addEventListener('drop', e => {
      e.preventDefault();
      const newOrder = [...container.querySelectorAll('.list-item-row')].map(r=>r.dataset.list);
      state.lists = newOrder;
      save();
      renderSettings();
    });
  });
}

