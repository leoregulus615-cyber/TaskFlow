function handleIcalDragOver(e) {
  e.preventDefault();
  e.currentTarget.classList.add('drag-over');
}
function handleIcalDragLeave(e) {
  e.currentTarget.classList.remove('drag-over');
}
function handleIcalDrop(e) {
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if(file) importIcalFile(file);
}
function handleIcalFileSelect(e) {
  const file = e.target.files[0];
  if(file) importIcalFile(file);
  e.target.value = '';
}
function importIcalFile(file) {
  if(!file.name.endsWith('.ics')) {
    showToast('올바른 .ics 파일을 업로드해주세요', 'error');
    return;
  }
  const reader = new FileReader();
  reader.onload = function(e) {
    const text = e.target.result;
    const events = parseICS(text);
    if(!events.length) {
      showToast('가져올 수 있는 일정이 없습니다', 'error');
      return;
    }
    let count = 0;
    events.forEach(ev => {
      const exists = state.todos.some(t => t.title === ev.title && t.due === ev.date);
      if(!exists) {
        const t = {
          id: genId(), title: ev.title || '(제목 없음)', desc: ev.desc || '', priority: 'medium',
          list: state.lists[0] || '개인', due: ev.date || todayStr(), repeat: 'none',
          pinned: false, done: false, tags: ['구글캘린더'], subtasks: [], created: new Date().toISOString()
        };
        state.todos.push(t);
        count++;
      }
    });
    save();
    updateBadges();
    renderView(state.currentView);
    showToast(`구글 캘린더에서 ${count}개의 일정을 가져왔습니다 🎉`, 'success');
  };
  reader.readAsText(file);
}
function parseICS(text) {
  const events = [];
  const lines = text.split(/\r?\n/);
  let currentEvent = null;
  let inEvent = false;
  for (let i = 0; i < lines.length; i++) {
    let line = lines[i];
    while (i + 1 < lines.length && (lines[i+1].startsWith(' ') || lines[i+1].startsWith('\t'))) {
      line += lines[i+1].substring(1);
      i++;
    }
    const trimmed = line.trim();
    if(trimmed === 'BEGIN:VEVENT') {
      currentEvent = {};
      inEvent = true;
    } else if(trimmed === 'END:VEVENT') {
      if(currentEvent && currentEvent.title) {
        events.push(currentEvent);
      }
      currentEvent = null;
      inEvent = false;
    } else if(inEvent && currentEvent) {
      const match = line.match(/^([^;:]+)(;[^:]+)?:(.*)$/);
      if(match) {
        const key = match[1].toUpperCase();
        let value = match[3];
        value = value.replace(/\\(.)/g, "$1").replace(/\\n/gi, "\n");
        if(key === 'SUMMARY') {
          currentEvent.title = value;
        } else if(key === 'DESCRIPTION') {
          currentEvent.desc = value;
        } else if(key === 'DTSTART') {
          let dateStr = value;
          if(dateStr.length >= 8) {
            const y = dateStr.substring(0, 4);
            const m = dateStr.substring(4, 6);
            const d = dateStr.substring(6, 8);
            currentEvent.date = `${y}-${m}-${d}`;
            if(dateStr.includes('T') && dateStr.length >= 13) {
              currentEvent.time = `${dateStr.substring(9, 11)}:${dateStr.substring(11, 13)}`;
            }
          }
        }
      }
    }
  }
  return events;
}
async function connectGcalWithManualToken() {
  const tokenInput = document.getElementById('gcal-manual-token');
  const token = tokenInput?.value?.trim();
  if(!token) {
    showToast('Google Access Token을 입력해주세요', 'error');
    return;
  }
  showToast('연결 중...', 'info');
  state.gcal = { connected: true, account: '', token: token, events: [], calendars: [] };
  try {
    const profileRes = await fetch('https://www.googleapis.com/oauth2/v2/userinfo', {
      headers: { Authorization: 'Bearer ' + token }
    });
    if(profileRes.ok) {
      const profile = await profileRes.json();
      state.gcal.account = profile.email || profile.name || 'Google 계정';
      if(profile.picture) state.gcal.picture = profile.picture;
      save();
      renderGcal();
      await fetchGcalData();
      showToast((state.gcal.account ? state.gcal.account + ' ' : '') + '연동 성공 🎉', 'success');
      if(tokenInput) tokenInput.value = '';
    } else {
      state.gcal = { connected: false, account: '', token: '', events: [], calendars: [] };
