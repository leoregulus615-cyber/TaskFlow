let _goalDraggingTodoId = null;
let _goalDraggingGoalId = null;
function goalTodoDragStart(e, goalId, todoId) {
  _goalDraggingTodoId = todoId;
  _goalDraggingGoalId = goalId;
  e.dataTransfer.setData('text', todoId);
  e.dataTransfer.effectAllowed = 'move';
  setTimeout(() => { if(e.target) e.target.style.opacity = '0.4'; }, 0);
}
function goalTodoDragEnd(e) {
  if(e.target) e.target.style.opacity = '1';
  _goalDraggingTodoId = null; _goalDraggingGoalId = null;
}
function goalTodoDragOver(e) { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; }
function goalTodoDrop(e, goalId) {
  e.preventDefault();
  const targetTodoId = e.currentTarget.dataset.todoId;
  if(!_goalDraggingTodoId || _goalDraggingTodoId === targetTodoId || _goalDraggingGoalId !== goalId) return;
  const goal = state.goals.find(g=>g.id===goalId);
  if(!goal || !goal.linkedTodos) return;
  const fromIdx = goal.linkedTodos.indexOf(_goalDraggingTodoId);
  const toIdx = goal.linkedTodos.indexOf(targetTodoId);
  if(fromIdx < 0 || toIdx < 0) return;
  goal.linkedTodos.splice(fromIdx, 1);
  goal.linkedTodos.splice(toIdx, 0, _goalDraggingTodoId);
  _goalDraggingTodoId = null; _goalDraggingGoalId = null;
  save(); renderGoals();
}

