  for(let i=0;i<first;i++) { const d=prevDays-first+1+i; cells+=`<div class="cal-day other-month"><span class="cal-num">${d}</span></div>`; }
  const td = todayStr();
  for(let d=1;d<=daysInMonth;d++) {
    const dStr = `${yr}-${String(mo+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday = dStr===td;
    const isSel = dStr===state.calSelectedDate;
    const dueTodos = state.todos.filter(t=>t.due===dStr);
    const startTodos = state.todos.filter(t=>t.start===dStr && t.due!==dStr);
    const ddayOn = state.ddays.some(dd=>dd.date===dStr);
    const dots = (dueTodos.length?'<div class="cal-dot"></div>':'') + (startTodos.length?'<div class="cal-dot cal-dot-start"></div>':'') + (ddayOn?'<div class="cal-dot cal-dot-dday"></div>':'');
    cells += `<div class="cal-day ${isToday?'today':''} ${isSel?'selected':''}" onclick="selectCalDay('${dStr}')">
      <span class="cal-num">${d}</span>${dots}
    </div>`;
  }
  const remaining = 42 - first - daysInMonth;
  for(let i=1;i<=remaining;i++) cells+=`<div class="cal-day other-month"><span class="cal-num">${i}</span></div>`;
  document.getElementById('calendar-grid').innerHTML = cells;
  if(state.calSelectedDate) renderCalDayTodos();
}
function selectCalDay(d) { state.calSelectedDate = d; closeCalDetail(); renderCalendar(); }
function renderCalDayTodos() {
  const d = state.calSelectedDate;
  document.getElementById('cal-selected-label').textContent = d ? fmtFull(d) : '날짜 선택';
  const ddaySec = document.getElementById('cal-dday-section');
  if(ddaySec) {
    const onDay = state.ddays.filter(dd => dd.date === d);
    const upcoming = state.ddays.filter(dd => {
      const diff = diffDays(dd.date, d);
      return diff > 0 && diff <= 14;
    }).slice(0, 3);
    const items = [...onDay, ...upcoming.filter(u => !onDay.find(o => o.id === u.id))];
    if(items.length) {
      ddaySec.innerHTML = `<div class="cal-goal-section-label">🚩 D-Day</div>` +
        items.map(dd => {
          const diff = diffDays(dd.date, d);
          const label = diff === 0 ? 'D-Day' : diff > 0 ? `D-${diff}` : `D+${Math.abs(diff)}`;
          return `<div class="cal-goal-item cal-dday-item" onclick="showCalDetailDday('${dd.id}')"><strong>${label}</strong> ${dd.name}</div>`;
        }).join('') +
        `<div class="cal-goal-actions"><button class="btn-add-todo" style="font-size:11px;padding:4px 10px" onclick="openDdayModalForDate('${d}')"><i class="fa-solid fa-plus"></i> D-Day 추가</button></div>`;
    } else ddaySec.innerHTML = `<div class="cal-goal-section-label">🚩 D-Day</div><div style="font-size:12px;color:var(--text-muted);padding:4px 0">이 날짜 근처 D-Day 없음</div>
      <div class="cal-goal-actions"><button class="filter-btn" style="font-size:11px" onclick="openDdayModalForDate('${d}')">+ D-Day</button></div>`;
  }
  let todos = filterHideCompleted(state.todos.filter(t=>t.due===d || t.start===d));
  const el = document.getElementById('cal-day-todos');
  if(!el) return;
  if(!todos.length) { el.innerHTML = `<div class="empty-state"><i class="fa-solid fa-check-circle"></i><p>이 날 할 일이 없습니다</p></div>`; return; }
  el.innerHTML = sortedTodos(todos).map(t => {
    const role = t.due===d && t.start===d ? '시작·마감' : t.due===d ? '마감' : '시작';
    return `<div class="todo-item" style="cursor:pointer" onclick="showCalDetailTodo('${t.id}')">
      <div class="priority-dot priority-${t.priority}"></div>
      <div style="flex:1"><div style="font-size:14px;font-weight:500">${t.title}</div>
      <div style="font-size:11px;color:var(--text-muted);margin-top:2px">${role} · ${priorityBadge(t.priority)}</div></div>
      <button class="todo-action" onclick="event.stopPropagation();openTodoModal('${t.id}')"><i class="fa-solid fa-pen"></i></button>
    </div>`;
  }).join('');
  const mk = monthKeyForDateStr(d);
  const wk = weekKeyForDateStr(d);
  const mBig = (state.monthlyBigGoals || {})[mk] || '';
  const wBig = (state.weeklyBigGoals || {})[wk] || '';
  const mSec = document.getElementById('cal-monthly-goals-section');
  const wSec = document.getElementById('cal-weekly-goals-section');
  if(mSec) {
    const mGoals = state.goals.filter(g=>g.type==='monthly' && g.periodKey===mk);
    mSec.innerHTML = `<div class="cal-goal-section-label">📋 월간 목표 <span style="font-weight:400;opacity:0.7">${formatGoalsMonthLabel(mk)}</span></div>` +
      (mBig ? `<div class="cal-goal-item cal-goal-big" onclick="showCalDetailBigGoal('monthly','${mk}')">⭐ ${mBig}</div>` : '') +
      mGoals.map(g=>`<div class="cal-goal-item" onclick="showCalDetailGoal('${g.id}')">${g.title}</div>`).join('') +
      `<div class="cal-goal-actions">
        <button class="btn-add-todo" style="font-size:11px;padding:4px 10px" onclick="openCalGoalModal('monthly')"><i class="fa-solid fa-plus"></i> 세부 목표</button>
        <button class="filter-btn" style="font-size:11px" onclick="editCalBigGoal('monthly')">핵심 목표</button>
      </div>`;
  }
  if(wSec) {
    const wGoals = state.goals.filter(g=>g.type==='weekly' && g.periodKey===wk);
    wSec.innerHTML = `<div class="cal-goal-section-label">🎯 주간 목표 <span style="font-weight:400;opacity:0.7">${formatGoalsWeekLabel(wk)}</span></div>` +
      (wBig ? `<div class="cal-goal-item cal-goal-big" onclick="showCalDetailBigGoal('weekly','${wk}')">⭐ ${wBig}</div>` : '') +
      wGoals.map(g=>`<div class="cal-goal-item" onclick="showCalDetailGoal('${g.id}')">${g.title}</div>`).join('') +
      `<div class="cal-goal-actions">
        <button class="btn-add-todo" style="font-size:11px;padding:4px 10px" onclick="openCalGoalModal('weekly')"><i class="fa-solid fa-plus"></i> 세부 목표</button>
        <button class="filter-btn" style="font-size:11px" onclick="editCalBigGoal('weekly')">핵심 목표</button>
      </div>`;
  }
}
function openCalGoalModal(type) {
  if(!state.calSelectedDate) { showToast('날짜를 먼저 선택하세요', 'info'); return; }
  if(type === 'weekly') {
    const targetSunday = new Date(weekKeyForDateStr(state.calSelectedDate) + 'T12:00:00');
    const currentSunday = getSundayOfDate(new Date());
    state.goalsWeekOffset = Math.round((targetSunday - currentSunday) / (7 * 86400000));
  } else {
    const sel = new Date(state.calSelectedDate + 'T12:00:00');
    const now = new Date();
    state.goalsMonthOffset = (sel.getFullYear() - now.getFullYear()) * 12 + (sel.getMonth() - now.getMonth());
  }
  openGoalModal(type);
}
function editCalBigGoal(type) {
  if(!state.calSelectedDate) return;
  const key = type === 'weekly' ? weekKeyForDateStr(state.calSelectedDate) : monthKeyForDateStr(state.calSelectedDate);
  const cur = type === 'weekly' ? ((state.weeklyBigGoals||{})[key]||'') : ((state.monthlyBigGoals||{})[key]||'');
  const val = prompt(type === 'weekly' ? '이번 주 핵심 목표' : '이번 달 핵심 목표', cur);
  if(val === null) return;
  if(type === 'weekly') {
    if(!state.weeklyBigGoals) state.weeklyBigGoals = {};
    state.weeklyBigGoals[key] = val;
  } else {
    if(!state.monthlyBigGoals) state.monthlyBigGoals = {};
    state.monthlyBigGoals[key] = val;
  }
  save();
  renderCalDayTodos();
  showToast('핵심 목표가 저장되었습니다', 'success');
}
function changeMonth(dir) { state.calMonth += dir; if(state.calMonth<0){state.calMonth=11;state.calYear--;} if(state.calMonth>11){state.calMonth=0;state.calYear++;} renderCalendar(); }
function goToToday() { state.calYear=new Date().getFullYear(); state.calMonth=new Date().getMonth(); state.calSelectedDate=todayStr(); renderCalendar(); }

// ========== WEEKLY ==========
function renderWeekly() {
  const days = ['일','월','화','수','목','금','토'];
  const now = new Date(); now.setHours(0,0,0,0);
  const startOfWeek = new Date(now); startOfWeek.setDate(now.getDate() - now.getDay() + state.weekOffset*7);
  const endOfWeek = new Date(startOfWeek); endOfWeek.setDate(startOfWeek.getDate()+6);
  document.getElementById('week-label').textContent = `${fmtFull(startOfWeek.toISOString().split('T')[0])} ~ ${fmtFull(endOfWeek.toISOString().split('T')[0])}`;
  let html = '';
  for(let i=0;i<7;i++) {
    const d = new Date(startOfWeek); d.setDate(startOfWeek.getDate()+i);
    const dStr = d.toISOString().split('T')[0];
    const isToday = dStr===todayStr();
    const dayTodos = state.todos.filter(t=>t.due===dStr);
    html += `<div class="week-col ${isToday?'today-col':''}">
      <div class="week-col-header">${days[d.getDay()]}</div>
      <div class="week-col-date">${d.getDate()}</div>
      ${dayTodos.map(t=>`<div class="week-todo" onclick="openTodoModal('${t.id}')" title="${t.title}">${t.title}</div>`).join('')}
    </div>`;
  }
  document.getElementById('week-grid').innerHTML = html;
}
function changeWeek(dir) { state.weekOffset += dir; renderWeekly(); }

// ========== GOALS ==========
function renderGoals() {
  const wk = getGoalsWeekKey();
  const mk = getGoalsMonthKey();
  const wLabel = document.getElementById('goals-week-label');
  const mLabel = document.getElementById('goals-month-label');
  if(wLabel) wLabel.textContent = formatGoalsWeekLabel(wk);
  if(mLabel) mLabel.textContent = formatGoalsMonthLabel(mk);
  const weekly = state.goals.filter(g=>g.type==='weekly' && g.periodKey===wk);
  const monthly = state.goals.filter(g=>g.type==='monthly' && g.periodKey===mk);

  const renderGoalList = (goals, container) => {
    const el = document.getElementById(container);
    if(!goals.length) { el.innerHTML = `<div class="empty-state"><i class="fa-solid fa-bullseye"></i><p>목표를 추가해보세요</p></div>`; return; }
    el.innerHTML = goals.map(g => {
      if(!g.linkedTodos) g.linkedTodos = [];
      const linked = g.linkedTodos.map(id => state.todos.find(t=>t.id===id)).filter(Boolean);
      const done = linked.filter(t=>t.done).length;
      const total = linked.length;
      const pct = total ? Math.round((done/total)*100) : 0;
      const todosHtml = linked.length
        ? `<div id="goal-todos-${g.id}">` + linked.map(t => {
            const subs = (t.subtasks||[]);
            const subsHtml = subs.length ? `<div style="padding-left:26px;margin-top:3px;margin-bottom:2px">` +
              subs.map(s=>`<div style="display:flex;align-items:center;gap:6px;padding:2px 0;font-size:11px;color:${s.done?'var(--text-muted)':'var(--text-secondary)'};${s.done?'text-decoration:line-through':''}">
                <i class="fa-${s.done?'solid':'regular'} fa-circle-check" style="font-size:9px;color:${s.done?'var(--success)':'var(--text-muted)'}"></i>${s.title}</div>`).join('') + `</div>` : '';
            return `<div class="goal-linked-todo" draggable="true" data-goal-id="${g.id}" data-todo-id="${t.id}"
              ondragstart="goalTodoDragStart(event,'${g.id}','${t.id}')"
              ondragover="goalTodoDragOver(event)"
              ondrop="goalTodoDrop(event,'${g.id}')"
              ondragend="goalTodoDragEnd(event)"
              style="padding:7px 0;border-bottom:1px solid var(--border);transition:opacity 0.15s">
              <div style="display:flex;align-items:center;gap:8px">
                <span style="color:var(--text-muted);cursor:grab;font-size:10px;flex-shrink:0"><i class="fa-solid fa-grip-lines"></i></span>
                <div class="todo-check ${t.done?'checked':''}" onclick="event.stopPropagation();toggleDone('${t.id}')"></div>
                <div style="flex:1;font-size:13px;${t.done?'text-decoration:line-through;color:var(--text-muted)':''}"> ${t.title}</div>
                <button class="todo-action" onclick="event.stopPropagation();openTodoModal('${t.id}')" title="편집"><i class="fa-solid fa-pen"></i></button>
                <button class="todo-action" onclick="event.stopPropagation();unlinkTodoFromGoal('${g.id}','${t.id}')" title="연결 해제"><i class="fa-solid fa-xmark"></i></button>
              </div>
              ${subsHtml}
            </div>`;
          }).join('') + `</div>`
        : `<div style="font-size:12px;color:var(--text-muted);padding:10px 0 6px">연결된 투두가 없습니다. 아래 버튼으로 추가하세요.</div>`;
      return `<div class="goal-card">
        <div class="goal-header">
          <div class="goal-title">${g.title}</div>
          <div style="display:flex;gap:6px;align-items:center">
            ${total ? `<div class="goal-percent">${pct}%</div>` : ''}
            <button class="todo-action" onclick="openGoalModal('${g.type}','${g.id}')" title="편집"><i class="fa-solid fa-pen"></i></button>
            <button class="todo-action" onclick="confirmDeleteGoal('${g.id}')"><i class="fa-solid fa-trash"></i></button>
          </div>
        </div>
        ${total ? `<div class="progress-bar" style="margin-bottom:6px"><div class="progress-fill ${pct>=100?'success':''}" style="width:${pct}%"></div></div><div class="goal-meta">${done} / ${total} 완료</div>` : ''}
        <div style="margin-top:10px">${todosHtml}</div>
        <div style="display:flex;gap:6px;margin-top:12px">
          <button class="btn-add-todo" onclick="openTodoModalForGoal('${g.id}')" style="flex:1;justify-content:center;font-size:12px"><i class="fa-solid fa-plus"></i> 새 투두</button>
          <button onclick="openGoalLinkModal('${g.id}')" style="font-size:12px;padding:6px 12px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--bg-tertiary);color:var(--text-secondary);cursor:pointer"><i class="fa-solid fa-link"></i> 기존 연결</button>
        </div>
      </div>`;
    }).join('');
  };

  renderGoalList(weekly, 'weekly-goals-list');
  renderGoalList(monthly, 'monthly-goals-list');
  const wInp = document.getElementById('weekly-big-goal-input');
  if(wInp) wInp.value = (state.weeklyBigGoals || {})[wk] || '';
  const mInp = document.getElementById('monthly-big-goal-input');
  if(mInp) mInp.value = (state.monthlyBigGoals || {})[mk] || '';
}

function openGoalModal(type, editId) {
  document.getElementById('goal-type-hidden').value = editId ? (state.goals.find(g=>g.id===editId)?.type||type) : (type||'weekly');
  document.getElementById('goal-edit-id').value = editId || '';
  document.getElementById('goal-title-input').value = '';
  document.getElementById('goal-delete-btn').style.display = 'none';
  document.querySelector('#goal-modal .modal-title').textContent = '목표 추가';
  if(editId) {
    const g = state.goals.find(x=>x.id===editId);
    if(g) { document.getElementById('goal-title-input').value = g.title; document.getElementById('goal-delete-btn').style.display = 'inline-flex'; document.querySelector('#goal-modal .modal-title').textContent = '목표 편집'; }
  }
  document.getElementById('goal-modal').classList.add('open');
  setTimeout(() => document.getElementById('goal-title-input').focus(), 100);
}
function closeGoalModal() { document.getElementById('goal-modal').classList.remove('open'); }
function saveGoal() {
  const title = document.getElementById('goal-title-input').value.trim();
  if(!title) { showToast('목표 내용을 입력해주세요', 'error'); return; }
  const id = document.getElementById('goal-edit-id').value;
  const type = document.getElementById('goal-type-hidden').value;
  const existing = id ? state.goals.find(x=>x.id===id) : null;
  const periodKey = existing?.periodKey || (type === 'weekly' ? getGoalsWeekKey() : getGoalsMonthKey());
  const g = { id: id||genId(), title, type, periodKey, linkedTodos: existing?.linkedTodos || [] };
  if(id) { const idx=state.goals.findIndex(x=>x.id===id); if(idx>=0) state.goals[idx]=g; } else state.goals.push(g);
  save(); closeGoalModal(); renderGoals();
  if(state.currentView === 'calendar') renderCalDayTodos();
  showToast('목표가 저장되었습니다', 'success');
}
function deleteGoalFromModal() {
  const id = document.getElementById('goal-edit-id').value;
  if(id && confirm('목표를 삭제하시겠어요?')) {
    state.goals = state.goals.filter(g=>g.id!==id);
    save(); closeGoalModal(); renderGoals();
    if(state.currentView === 'calendar') renderCalDayTodos();
    showToast('목표가 삭제되었습니다', 'info');
  }
}
function confirmDeleteGoal(id) {
  if(confirm('목표를 삭제하시겠어요?')) {
    state.goals = state.goals.filter(g=>g.id!==id);
    save(); renderGoals();
    if(state.currentView === 'calendar') renderCalDayTodos();
    showToast('목표가 삭제되었습니다', 'info');
  }
}
