// ========== ALL ==========
function groupTodos(todos, groupBy) {
  if(groupBy === 'list') {
    const g = {};
    todos.forEach(t => { const k = t.list || '목록 없음'; if(!g[k]) g[k]=[]; g[k].push(t); });
    return g;
  } else if(groupBy === 'date') {
    const g = { '📅 오늘':[], '📆 이번 주':[], '🗓️ 이번 달':[], '⏳ 이후':[], '❌ 기한 없음':[] };
    const td = todayStr();
    const we = new Date(); we.setDate(we.getDate()+7);
    const me = new Date(); me.setDate(me.getDate()+30);
    todos.forEach(t => {
      if(!t.due) { g['❌ 기한 없음'].push(t); return; }
      if(t.due <= td) { g['📅 오늘'].push(t); return; }
      if(new Date(t.due) <= we) { g['📆 이번 주'].push(t); return; }
      if(new Date(t.due) <= me) { g['🗓️ 이번 달'].push(t); return; }
      g['⏳ 이후'].push(t);
    });
    return g;
  } else if(groupBy === 'priority') {
    const g = {};
    ['urgent','high','medium','low'].forEach(p => { g[getPriorityGroupLabel(p)] = []; });
    todos.forEach(t => { const k = getPriorityGroupLabel(t.priority); if(g[k]) g[k].push(t); });
    return g;
  } else if(groupBy === 'tag') {
    const g = {};
    todos.forEach(t => {
      if(!(t.tags||[]).length) { if(!g['🏷️ 태그 없음']) g['🏷️ 태그 없음']=[]; g['🏷️ 태그 없음'].push(t); }
      else (t.tags||[]).forEach(tag => { if(!g[tag]) g[tag]=[]; g[tag].push(t); });
    });
    return g;
  }
  return { '전체': todos };
}
function renderGroupedList(container, todos, emptyMsg) {
  const el = document.getElementById(container);
  if(!el) return;
  todos = filterHideCompleted(todos);
  if(!todos.length) { el.innerHTML = `<div class="empty-state"><i class="fa-solid fa-check-circle"></i><p>${emptyMsg||'할 일이 없습니다'}</p></div>`; return; }
  const groups = groupTodos(todos, state.todoGroupBy);
  let html = '';
  for(const [key, items] of Object.entries(groups)) {
    if(!items.length) continue;
    const sorted = sortedTodos(items);
    const pinned = sorted.filter(t=>t.pinned);
    const rest = sorted.filter(t=>!t.pinned);
    let inner = pinned.map(t=>renderTodoItem(t)).join('');
    if(pinned.length && rest.length) inner += `<div class="pinned-group-divider"></div>`;
    inner += rest.map(t=>renderTodoItem(t)).join('');
    html += `<div class="group-section"><div class="group-section-label">${key} <span style="font-weight:400;opacity:0.7">(${items.length})</span></div>${inner}</div>`;
  }
  el.innerHTML = html || `<div class="empty-state"><i class="fa-solid fa-check-circle"></i><p>${emptyMsg||'할 일이 없습니다'}</p></div>`;
}
