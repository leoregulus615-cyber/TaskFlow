let activeMiniCalField = null;
function syncMiniCalDisplays() {
  ['start','due'].forEach(field => {
    const val = document.getElementById('todo-' + field + '-input')?.value;
    const disp = document.getElementById('mini-cal-' + field + '-display');
    if(!disp) return;
    if(val) { disp.textContent = fmtFull(val); disp.classList.remove('empty'); }
    else { disp.textContent = '날짜 없음'; disp.classList.add('empty'); }
  });
}
function toggleMiniCal(field, e) {
  e.stopPropagation();
  const popup = document.getElementById('mini-cal-' + field + '-popup');
  const other = field === 'start' ? 'due' : 'start';
  document.getElementById('mini-cal-' + other + '-popup')?.classList.remove('open');
  if(!popup) return;
  const opening = !popup.classList.contains('open');
  document.querySelectorAll('.mini-cal-popup').forEach(p => p.classList.remove('open'));
  if(opening) {
    popup.classList.add('open');
    activeMiniCalField = field;
    if(field === 'start' && !state.miniCalStartMonth) state.miniCalStartMonth = { y: new Date().getFullYear(), m: new Date().getMonth() };
    if(field === 'due' && !state.miniCalDueMonth) state.miniCalDueMonth = { y: new Date().getFullYear(), m: new Date().getMonth() };
    renderMiniCalendar(field);
  } else activeMiniCalField = null;
}
function changeMiniCalMonth(field, dir) {
  const key = field === 'start' ? 'miniCalStartMonth' : 'miniCalDueMonth';
  if(!state[key]) state[key] = { y: new Date().getFullYear(), m: new Date().getMonth() };
  state[key].m += dir;
  if(state[key].m < 0) { state[key].m = 11; state[key].y--; }
  if(state[key].m > 11) { state[key].m = 0; state[key].y++; }
  renderMiniCalendar(field);
}
function renderMiniCalendar(field) {
  const popup = document.getElementById('mini-cal-' + field + '-popup');
  if(!popup) return;
  const key = field === 'start' ? 'miniCalStartMonth' : 'miniCalDueMonth';
  if(!state[key]) state[key] = { y: new Date().getFullYear(), m: new Date().getMonth() };
  const yr = state[key].y, mo = state[key].m;
  const selected = document.getElementById('todo-' + field + '-input')?.value || '';
  const days = ['일','월','화','수','목','금','토'];
  let cells = days.map(d => `<div class="cal-header">${d}</div>`).join('');
  const first = new Date(yr, mo, 1).getDay();
  const daysInMonth = new Date(yr, mo + 1, 0).getDate();
  const prevDays = new Date(yr, mo, 0).getDate();
  const td = todayStr();
  for(let i = 0; i < first; i++) cells += `<div class="cal-day other-month"><span class="cal-num">${prevDays - first + 1 + i}</span></div>`;
  for(let d = 1; d <= daysInMonth; d++) {
    const dStr = `${yr}-${String(mo+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday = dStr === td;
    const isSel = dStr === selected;
    cells += `<div class="cal-day ${isToday?'today':''} ${isSel?'selected':''}" onclick="pickMiniCalDay('${field}','${dStr}')"><span class="cal-num">${d}</span></div>`;
  }
  const rem = 42 - first - daysInMonth;
  for(let i = 1; i <= rem; i++) cells += `<div class="cal-day other-month"><span class="cal-num">${i}</span></div>`;
  popup.innerHTML = `<div class="cal-nav" style="margin-bottom:4px">
    <button type="button" class="cal-nav-btn" onclick="event.stopPropagation();changeMiniCalMonth('${field}',-1)"><i class="fa-solid fa-chevron-left"></i></button>
    <span class="cal-month-label" style="font-size:13px">${yr}년 ${mo+1}월</span>
    <button type="button" class="cal-nav-btn" onclick="event.stopPropagation();changeMiniCalMonth('${field}',1)"><i class="fa-solid fa-chevron-right"></i></button>
  </div>
  <div class="calendar-grid">${cells}</div>
  <div class="mini-cal-clear" onclick="pickMiniCalDay('${field}','')">날짜 지우기</div>`;
}
function pickMiniCalDay(field, dStr) {
  const inp = document.getElementById('todo-' + field + '-input');
  if(inp) inp.value = dStr;
  document.getElementById('mini-cal-' + field + '-popup')?.classList.remove('open');
  syncMiniCalDisplays();
}
