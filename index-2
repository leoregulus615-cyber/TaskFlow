function sortedTodos(arr) {
  const pinned = arr.filter(t=>t.pinned).sort((a,b)=>PRIORITY_ORDER[a.priority]-PRIORITY_ORDER[b.priority]);
  const rest = arr.filter(t=>!t.pinned);
  let sorted = [...rest];
  if(state.currentSort==='priority') sorted.sort((a,b)=>PRIORITY_ORDER[a.priority]-PRIORITY_ORDER[b.priority]);
  else if(state.currentSort==='due') sorted.sort((a,b)=>{if(!a.due&&!b.due)return 0;if(!a.due)return 1;if(!b.due)return -1;return new Date(a.due)-new Date(b.due);});
  else if(state.currentSort==='title') sorted.sort((a,b)=>a.title.localeCompare(b.title,'ko'));
  else sorted.sort((a,b)=>new Date(b.created)-new Date(a.created));
  return [...pinned, ...sorted];
}

