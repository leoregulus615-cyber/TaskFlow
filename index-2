<!-- 컨텍스트 메뉴 구조 -->
<div id="context-menu">
  <div class="menu-item" onclick="handleMenu('edit')">편집</div>
  <div class="menu-item" onclick="handleMenu('done')">완료/취소</div>
  <div class="menu-item" onclick="handleMenu('goal')"><i class="fa-solid fa-bullseye" style="margin-right:6px;font-size:11px;color:var(--accent)"></i>목표에 등록</div>
  <div class="menu-item" onclick="handleMenu('delete')" style="color:var(--danger)">삭제</div>
</div>

<script>
  // 1. 우클릭 메뉴 구현
  document.addEventListener('contextmenu', e => {
    const todoItem = e.target.closest('.todo-item');
    if (todoItem) {
      e.preventDefault();
      const menu = document.getElementById('context-menu');
      menu.style.display = 'block';
      menu.style.left = e.pageX + 'px';
      menu.style.top = e.pageY + 'px';
      menu.dataset.id = todoItem.dataset.id;
    }
  });
  document.addEventListener('click', () => document.getElementById('context-menu').style.display = 'none');

  function handleMenu(action) {
    const id = document.getElementById('context-menu').dataset.id;
    if (action === 'edit') openTodoModal(id);
    else if (action === 'done') toggleDone(id);
    else if (action === 'goal') openGoalAssignModal(id);
    else if (action === 'delete') { 
      if(confirm('삭제하시겠습니까?')) { state.todos = state.todos.filter(x=>x.id!==id); renderView(state.currentView);
updateFabVisibility();
renderStopwatch();
initSidebarSort();
applySidebarModes(); }
    }
  }

  // 2. 모달 외부 클릭 시 닫기
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', e => {
      if (e.target === overlay) {
        overlay.classList.remove('open');
      }
    });
  });

</script>

<script>
const TAG_COLORS = ['#6c63ff','#22c55e','#f59e0b','#ef4444','#3b82f6','#ec4899','#14b8a6','#f97316','#8b5cf6','#06b6d4'];
let state = {
  todos: [], lists: ['개인','업무','쇼핑','공부'], goals: [], ddays: [], habits: [],
  currentView: 'dashboard', currentFilter: 'all', currentTagFilter: 'all', selectedTags: [],
  currentSort: 'created', currentListFilter: 'all', upcomingFilter: 'tomorrow',
  goalsWeekOffset: 0, goalsMonthOffset: 0, weeklyBigGoals: {}, monthlyBigGoals: {},
  expandedSubtasks: {}, toastPosition: 'top-right',
  calYear: new Date().getFullYear(), calMonth: new Date().getMonth(),
  calSelectedDate: null, weekOffset: 0,
  pomo: { mode: 'work', running: false, time: 25*60, total: 25*60, sessions: 0, interval: null, work: 25, break: 5, long: 15 },
  gcal: { connected: false, account: '' }, theme: 'dark', accentColor: '#6c63ff',
  currentTodoTags: [], currentSubtasks: [], googleClientId: '', googleApiKey: '',
  notifBefore: 30, syncInterval: null, menuOrder: [], sfxVolume: 0.7, alarmVolume: 0.8, customSfx:null, customAlarm:null, sidebarIconOnly:false, sidebarHideIcons:false, stopwatch: { running:false, elapsed:0, interval:null, startedAt:null },
  todoEditMode: 'modal', weeklyBigGoal: '', monthlyBigGoal: '', todoGroupBy: 'none', todoViewMode: 'list',
  listViewModes: {}, hideCompleted: false,
  notes: [], noteEditColor: '#1e1e2e', hiddenMenus: [], currentAttachments: [],
  miniCalStartMonth: null, miniCalDueMonth: null,
  tagColors: {}, syncCode: '', syncEnabled: false
};
const DEFAULT_MENU_ORDER = ['dashboard','dump','today','upcoming','goals','weekly','calendar','dday','pomodoro','matrix','habits','notes','gcal','settings'];
const GOOGLE_CALENDAR_SCOPES = 'https://www.googleapis.com/auth/calendar.readonly https://www.googleapis.com/auth/calendar.events';
let gcalTokenClient = null;

function getGoogleClientId() {
  const inline = document.getElementById('gcal-inline-client-id')?.value?.trim();
  const settings = document.getElementById('google-client-id')?.value?.trim();
  return (state.googleClientId || inline || settings || '').trim();
}

function save() { try { localStorage.setItem('taskflow_state', JSON.stringify(state)); } catch(e){} }
function load() {
  try {
    const s = localStorage.getItem('taskflow_state');
    if (s) { const d = JSON.parse(s); Object.assign(state, d); state.pomo.running = false; state.pomo.interval = null; state.syncInterval = null; }
  } catch(e) {}
  if(state.currentView === 'gcal') state.currentView = 'settings';
  if(state.currentView === 'all') state.currentView = 'today';
  // Migrate old goals: ensure all goals have linkedTodos array
  state.goals.forEach(g => { if(!g.linkedTodos) g.linkedTodos = []; });
  if(!state.hiddenMenus) state.hiddenMenus = [];
  if(!state.todoViewMode) state.todoViewMode = 'list';
  if(!state.selectedTags) {
    state.selectedTags = state.currentTagFilter && state.currentTagFilter !== 'all' ? [state.currentTagFilter] : [];
  }
  if(!state.weeklyBigGoals) state.weeklyBigGoals = {};
  if(!state.monthlyBigGoals) state.monthlyBigGoals = {};
  if(state.weeklyBigGoal) { state.weeklyBigGoals[getGoalsWeekKey(0)] = state.weeklyBigGoal; delete state.weeklyBigGoal; }
  if(state.monthlyBigGoal) { state.monthlyBigGoals[getGoalsMonthKey(0)] = state.monthlyBigGoal; delete state.monthlyBigGoal; }
  const wk = getGoalsWeekKey(0), mk = getGoalsMonthKey(0);
  state.goals.forEach(g => {
    if(!g.periodKey) g.periodKey = g.type === 'weekly' ? wk : mk;
  });
  if(!state.expandedSubtasks) state.expandedSubtasks = {};
  if(!state.listViewModes) state.listViewModes = {};
  if(state.hideCompleted === undefined) state.hideCompleted = false;
  if(!state.menuOrder || !state.menuOrder.length || !state.menuOrder.includes('dump')) state.menuOrder = [...DEFAULT_MENU_ORDER];
  state.menuOrder = state.menuOrder.filter(v => v !== 'all');
  if(!state.tagColors) state.tagColors = {};
  if(!state.syncCode) state.syncCode = '';
  if(state.syncEnabled === undefined) state.syncEnabled = false;
  migrateTodoPriorityMatrix();
  migratePriorityLabels();
  applyToastPosition();
}
function genId() { return Date.now().toString(36) + Math.random().toString(36).substr(2,5); }
function fmt(d) { if(!d) return ''; const dt = new Date(d); return dt.toLocaleDateString('ko-KR',{month:'short',day:'numeric'}); }
function fmtFull(d) { if(!d) return ''; return new Date(d).toLocaleDateString('ko-KR',{year:'numeric',month:'long',day:'numeric'}); }
function today() { const d = new Date(); d.setHours(0,0,0,0); return d; }
function todayStr() { return today().toISOString().split('T')[0]; }
function isOverdue(due) { return due && new Date(due) < today(); }
function isSoon(due) { const diff = new Date(due) - today(); return diff >= 0 && diff <= 24*60*60*1000*2; }
function diffDays(a, b) { return Math.round((new Date(a) - new Date(b)) / 86400000); }

const PRIORITY_ORDER = { urgent:0, high:1, medium:2, low:3 };
const PRIORITY_TO_MATRIX = { urgent:'q1', high:'q2', medium:'q3', low:'q4' };
const MATRIX_TO_PRIORITY = { q1:'urgent', q2:'high', q3:'medium', q4:'low' };
const DEFAULT_PRIORITY_LABELS = { urgent:'긴급', high:'높음', medium:'위임', low:'낮음' };
function getPriorityLabel(p) {
  return (state.priorityLabels && state.priorityLabels[p]) || DEFAULT_PRIORITY_LABELS[p] || '위임';
}
function getPriorityGroupLabel(p) {
  const icons = { urgent:'🔴', high:'🟠', medium:'🔵', low:'⚪' };
  return `${icons[p]||'🔵'} ${getPriorityLabel(p)}`;
}
function migratePriorityLabels() {
  if(!state.priorityLabels || typeof state.priorityLabels !== 'object') state.priorityLabels = {...DEFAULT_PRIORITY_LABELS};
}
function savePriorityLabels() {
  state.priorityLabels = {
    urgent: document.getElementById('priority-label-urgent')?.value.trim() || DEFAULT_PRIORITY_LABELS.urgent,
    high: document.getElementById('priority-label-high')?.value.trim() || DEFAULT_PRIORITY_LABELS.high,
    medium: document.getElementById('priority-label-medium')?.value.trim() || DEFAULT_PRIORITY_LABELS.medium,
    low: document.getElementById('priority-label-low')?.value.trim() || DEFAULT_PRIORITY_LABELS.low,
  };
  save();
  renderView(state.currentView);
}
function resetPriorityLabels() {
  state.priorityLabels = {...DEFAULT_PRIORITY_LABELS};
  save();
  renderSettings();
  renderView(state.currentView);
  showToast('우선순위 이름이 기본값으로 복원되었습니다', 'info');
}
function applyToastPosition() {
  const c = document.getElementById('toast-container');
